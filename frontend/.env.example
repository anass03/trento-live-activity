# OAuth (Fase E1, E2) - configurabili dal professore
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_APPLE_CLIENT_ID=
VITE_APPLE_REDIRECT_URI=

# Firebase Cloud Messaging (notifiche push) — OPZIONALI.
# I default del progetto sono già hardcoded in src/lib/firebase.ts e nel
# service worker public/firebase-messaging-sw.js, quindi le notifiche
# funzionano out-of-the-box. Compila queste solo per puntare a un altro
# progetto Firebase.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
