# node_modules lives on a Windows drive (e.g. /mnt/f) that is also accessed from
# WSL. Creating POSIX symlinks there is denied (EPERM), and Git Bash otherwise
# writes broken "XSym" shims that WSL can't execute. Skip the .bin symlinks
# entirely — the package.json scripts invoke node directly, so they run the same
# on Windows, WSL and Linux CI without depending on node_modules/.bin.
bin-links=false
