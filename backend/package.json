{
  "name": "trento-live-activity-backend",
  "version": "1.0.0",
  "description": "Backend for Trento Live Activity civic-tech platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node node_modules/nodemon/bin/nodemon.js --legacy-watch src/server.js",
    "test": "node node_modules/jest/bin/jest.js --forceExit --detectOpenHandles",
    "test:coverage": "node node_modules/jest/bin/jest.js --coverage --forceExit --detectOpenHandles",
    "setup": "bash scripts/setup.sh",
    "seed": "node src/data/seed.js",
    "seed:university-pois": "node scripts/seed-university-pois.js",
    "migrate:consents": "node scripts/migrate-consent-types.js",
    "migrate:activity-types": "node scripts/migrate-activity-types.js",
    "backfill:dual-schema": "node scripts/backfill-dual-schema.js",
    "db:sync": "node -e \"require('./src/data/db').sync({ force: true }).then(() => { console.log('DB synced'); process.exit(0); })\""
  },
  "dependencies": {
    "@google/genai": "^2.3.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "firebase-admin": "^13.9.0",
    "google-auth-library": "^10.6.2",
    "jose": "^4.15.9",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.2",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.18.0",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
