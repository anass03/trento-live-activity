{
  "name": "trento-live-activity-backend",
  "version": "1.0.0",
  "description": "Backend for Trento Live Activity civic-tech platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node node_modules/jest/bin/jest.js --forceExit --detectOpenHandles",
    "test:coverage": "node node_modules/jest/bin/jest.js --coverage --forceExit --detectOpenHandles",
    "db:sync": "node -e \"require('./src/data/db').sync({ force: true }).then(() => { console.log('DB synced'); process.exit(0); })\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.14",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["src/**/*.js"]
  }
}
