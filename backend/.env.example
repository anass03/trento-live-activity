# Database
DATABASE_URL=postgres://user:password@localhost:5432/trento_live

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
MOCK_CURRENT_USER_EMAIL=mario.rossi@example.com

# SMTP (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=smtp-password
SMTP_FROM="Trento Live Activity <noreply@example.com>"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Chiave privata Apple p8 (multilinea: usa "\n" letterali oppure incolla il blocco)
APPLE_PRIVATE_KEY=

# Google Gemini API (AI suggester, D3)
# Ottieni la key gratis su https://aistudio.google.com/apikey (free tier: 1500 req/giorno).
# Lascia vuoto per disabilitare l'endpoint /api/ai/suggest-activity.
GEMINI_API_KEY=

# Firebase Cloud Messaging (RF40)
# Leave empty to log push notifications to console (stub mode).
# Set to the path of your Firebase service account JSON file to enable real push.
FIREBASE_CREDENTIALS_PATH=

# Maps
MAPS_API_KEY=
