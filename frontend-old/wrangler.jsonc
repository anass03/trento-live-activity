{
  // Config per deploy del frontend (SPA Vite/React) su Cloudflare Workers
  // tramite "static assets". Il build (`npm run build`) genera ./dist, che
  // viene servito come sito statico; not_found_handling=single-page-application
  // rimanda ogni rotta sconosciuta a index.html per il routing lato client.
  "name": "trento-live-activity",
  "compatibility_date": "2024-11-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
